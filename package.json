{
  "name": "todolist-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start:dev": "NODE_ENV=development vite",
    "start:mock_dev": "NODE_ENV=development vite --mode mock",
    "build": "NODE_ENV=production tsc -b && vite build",
    "dev": "vite",
    "lint": "eslint .",
    "preview": "vite preview",
    "format": "prettier --write .",
    "format:ci": "prettier --check .",
    "lint:ci": "tsc --build --noEmit && eslint . --report-unused-disable-directives --max-warnings 0",
    "test": "vitest",
    "test:ci": "vitest --coverage --watch=false"
  },
  "dependencies": {
    "@eslint/js": "^9.39.4",
    "@npm-questionpro/wick-ui-icon": "^9.0.0",
    "@npm-questionpro/wick-ui-lib": "^1.39.0",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-query-devtools": "^5.100.9",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@npm-questionpro/wick-ui-eslint-config-frontend": "^0.0.3",
    "@npm-questionpro/wick-ui-prettier-config": "^1.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.4",
    "prettier": "^3.8.3",
    "resize-observer-polyfill": "^1.5.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "prettier": "@npm-questionpro/wick-ui-prettier-config",
  "msw": {
    "workerDirectory": [
      ""
    ]
  }
}
